# Save as /etc/nginx/sites-available/epicfinance (adjust server_name and paths).
# sudo ln -s /etc/nginx/sites-available/epicfinance /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx
# Then: sudo certbot --nginx -d yourdomain.com -d www.yourdomain.com

server {
    listen 80;
    listen [::]:80;
    server_name yourdomain.com www.yourdomain.com;

    # Loan application uploads (multipart). Default 1m is too small.
    client_max_body_size 20m;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }
}
